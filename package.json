{
	"name": "high-performance-stocks",
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"cookie": "^0.7.0"
		}
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src scripts lib",
		"lint:fix": "eslint src scripts lib --fix",
		"lint:all": "pnpm run lint && pnpm run check",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"update-data": "tsx scripts/update-data.ts",
		"validate-data": "tsx scripts/validate-data.ts",
		"add-new-stocks": "tsx scripts/add-new-stocks.ts"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.7",
		"yahoo-finance2": "^3.13.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.54.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24.6.1",
		"@vitest/eslint-plugin": "^1.6.12",
		"dotenv": "^17.3.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-sonarjs": "^4.0.2",
		"eslint-plugin-svelte": "^3.15.2",
		"eslint-plugin-testing-library": "^7.16.1",
		"eslint-plugin-unicorn": "^63.0.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.11",
		"svelte-check": "^4.4.5",
		"svelte-eslint-parser": "^1.6.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.2.6",
		"vitest": "^4.1.0"
	}
}
