{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"strict": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"moduleResolution": "bundler",
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.d.ts"],
	"exclude": ["scripts/**", "node_modules/**", "data/**"]
}
