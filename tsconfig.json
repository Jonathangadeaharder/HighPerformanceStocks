{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"strict": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"moduleResolution": "bundler",
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.d.ts", "scripts/**/*.ts", "lib/**/*.js"],
	"exclude": ["node_modules/**", "data/**", "scripts/sandbox/**"]
}
